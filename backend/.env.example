# ────────────────────────────────────────────────────────────────────
# Azure OpenAI Configuration
# ────────────────────────────────────────────────────────────────────
# Get these from Azure Portal: portal.azure.com
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ────────────────────────────────────────────────────────────────────
# Storage Configuration
# ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=storage/invoices

# ────────────────────────────────────────────────────────────────────
# CORS Configuration
# ────────────────────────────────────────────────────────────────────
# For development with React Vite frontend on port 5173
ALLOWED_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# ────────────────────────────────────────────────────────────────────
# Instructions to get Azure OpenAI credentials:
# ────────────────────────────────────────────────────────────────────
# 1. Go to https://portal.azure.com/
# 2. Create or select an OpenAI resource
# 3. Navigate to "Keys and Endpoint" section
# 4. Copy ENDPOINT (e.g., https://my-resource.openai.azure.com/)
# 5. Copy API KEY (Key 1 or Key 2)
# 6. Copy these values to the variables above
# 7. Save this file as .env (without .example)
